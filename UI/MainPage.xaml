<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JarvisAssistant.UI.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0A0E1A">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" BackgroundColor="#0D1526" Padding="20,12" ColumnDefinitions="*,Auto,Auto">
            <VerticalStackLayout Grid.Column="0">
                <Label x:Name="AssistantNameLabel" Text="⚡ JARVIS"
                       FontSize="20" FontAttributes="Bold" TextColor="#00D4FF"/>
                <Label x:Name="StatusLabel" Text="Pronto." FontSize="12" TextColor="#8892A4"/>
            </VerticalStackLayout>

            <Button Grid.Column="1" x:Name="MicButton"
                    Text="🎤" FontSize="20"
                    BackgroundColor="#1E3A5F" TextColor="#00D4FF"
                    CornerRadius="22" WidthRequest="44" HeightRequest="44"
                    Clicked="OnMicClicked" Margin="0,0,8,0"/>

            <Button Grid.Column="2" Text="⚙️" FontSize="18"
                    BackgroundColor="#1E2D40" TextColor="#8892A4"
                    CornerRadius="22" WidthRequest="44" HeightRequest="44"
                    Clicked="OnSettingsClicked"/>
        </Grid>

        <!-- ── Chat Area ── -->
        <CollectionView x:Name="ChatList" Grid.Row="1"
                        ItemsSource="{Binding Messages}"
                        Margin="16,8" ItemsUpdatingScrollMode="KeepLastItemInView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,4">
                        <!-- Mensagem do usuário (direita) -->
                        <Frame IsVisible="{Binding IsUser}"
                               BackgroundColor="#1E3A5F" BorderColor="Transparent"
                               CornerRadius="16" Padding="14,10"
                               HorizontalOptions="End" MaximumWidthRequest="320">
                            <Label Text="{Binding Content}" TextColor="#E2E8F0" FontSize="14"/>
                        </Frame>

                        <!-- Mensagem do Jarvis (esquerda) -->
                        <Frame IsVisible="{Binding IsAssistant}"
                               BackgroundColor="#111827" BorderColor="#1E3A5F"
                               CornerRadius="16" Padding="14,10"
                               HorizontalOptions="Start" MaximumWidthRequest="340">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="⚡ Jarvis" TextColor="#00D4FF"
                                       FontSize="11" FontAttributes="Bold"/>
                                <Label Text="{Binding Content}" TextColor="#CBD5E0" FontSize="14"/>
                                <Label Text="{Binding TimeDisplay}" TextColor="#4A5568" FontSize="11"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ── Speaking indicator ── -->
        <HorizontalStackLayout x:Name="SpeakingIndicator" Grid.Row="2"
                                IsVisible="False" HorizontalOptions="Center"
                                Spacing="6" Margin="0,4">
            <ActivityIndicator IsRunning="True" Color="#00D4FF" HeightRequest="16" WidthRequest="16"/>
            <Label Text="Jarvis está falando..." TextColor="#00D4FF" FontSize="12"/>
        </HorizontalStackLayout>

        <!-- ── Input Area ── -->
        <Grid Grid.Row="3" Padding="12,8,12,16" ColumnDefinitions="*,Auto"
              BackgroundColor="#0D1526">
            <Frame Grid.Column="0" BackgroundColor="#111827" BorderColor="#1E3A5F"
                   CornerRadius="24" Padding="0" HasShadow="False">
                <Entry x:Name="MessageEntry"
                       Placeholder="Pergunte algo ao Jarvis..."
                       PlaceholderColor="#4A5568" TextColor="#E2E8F0"
                       BackgroundColor="Transparent" Margin="16,0"
                       ReturnCommand="{Binding SendCommand}"
                       ReturnType="Send"/>
            </Frame>

            <Button Grid.Column="1" x:Name="SendButton"
                    Text="➤" FontSize="18"
                    BackgroundColor="#00D4FF" TextColor="#0A0E1A"
                    FontAttributes="Bold"
                    CornerRadius="24" WidthRequest="48" HeightRequest="48"
                    Margin="8,0,0,0"
                    Clicked="OnSendClicked"/>
        </Grid>
    </Grid>
</ContentPage>
